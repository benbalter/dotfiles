#!/bin/bash
# Set up some common global variables
# This file is sourced by interactive shells; do NOT use `set -e`/`set -u`
# as that would alter the parent shell's behavior.

# Used internally
DOTFILES_ROOT=${DOTFILES_ROOT:-"$HOME/.files"}
export DOTFILES_ROOT

# Setup cli tools
if [ "$(uname)" = "Darwin" ]; then
	HOMEBREW_CASK_OPTS="--appdir=/Applications"
	export HOMEBREW_CASK_OPTS
fi

GOPATH=$HOME/go
export GOPATH

PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/local/sbin:$GOPATH/bin:$PATH"
export PATH

# ZSH settings and initializations
ZSH=$HOME/.oh-my-zsh
export ZSH

if command -v zsh >/dev/null 2>&1; then
	SHELL=$(command -v zsh)
	case "$SHELL" in
		/*) ;;
		*)
			SHELL=""
			for d in /opt/homebrew/bin /usr/local/bin /bin /usr/bin; do
				[ -x "$d/zsh" ] && SHELL="$d/zsh" && break
			done
			;;
	esac
	export SHELL
fi

ZSH_THEME=""
export ZSH_THEME

DISABLE_UPDATE_PROMPT=true
export DISABLE_UPDATE_PROMPT

COMPLETION_WAITING_DOTS="true"
export COMPLETION_WAITING_DOTS

# You've got mail
unset MAILCHECK

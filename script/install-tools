#!/bin/sh
# Install essential CLI tools on Linux for dotfiles compatibility.
# Called by install.sh (dotfiles integration) and post-create.sh (devcontainer).
# On macOS these tools are installed via Homebrew/Brewfile instead.

set -e

if [ "$(uname)" = "Darwin" ]; then
	echo "Skipping install-tools on macOS (use Homebrew instead)"
	exit 0
fi

install_delta() {
	if command -v delta >/dev/null; then return; fi
	echo "==> Installing delta..."
	ARCH=$(dpkg --print-architecture 2>/dev/null || echo "amd64")
	DELTA_DEB_URL=$(curl -sL https://api.github.com/repos/dandavison/delta/releases/latest |
		grep '"browser_download_url"' | grep "_${ARCH}\\.deb" | grep -v musl | sed 's/.*"browser_download_url": *"//;s/".*//')
	DELTA_DEB=$(basename "$DELTA_DEB_URL")
	curl -sLO "$DELTA_DEB_URL"
	sudo dpkg -i "$DELTA_DEB"
	rm -f "$DELTA_DEB"
}

install_zoxide() {
	if command -v zoxide >/dev/null; then return; fi
	echo "==> Installing zoxide..."
	ARCH=$(dpkg --print-architecture 2>/dev/null || echo "amd64")
	ZOXIDE_DEB_URL=$(curl -sL https://api.github.com/repos/ajeetdsouza/zoxide/releases/latest |
		grep '"browser_download_url"' | grep "_${ARCH}\\.deb" | sed 's/.*"browser_download_url": *"//;s/".*//')
	ZOXIDE_DEB=$(basename "$ZOXIDE_DEB_URL")
	curl -sLO "$ZOXIDE_DEB_URL"
	sudo dpkg -i "$ZOXIDE_DEB"
	rm -f "$ZOXIDE_DEB"
}

install_fzf() {
	if command -v fzf >/dev/null; then return; fi
	echo "==> Installing fzf..."
	git clone --depth 1 https://github.com/junegunn/fzf.git "$HOME/.fzf"
	"$HOME/.fzf/install" --bin --no-update-rc --no-completion --no-key-bindings
	sudo ln -sf "$HOME/.fzf/bin/fzf" /usr/local/bin/fzf
}

install_delta
install_zoxide
install_fzf

echo "==> Tool installation complete"

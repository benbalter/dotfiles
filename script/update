#!/bin/bash
# Update all installed dependencies
# Usage: up

set -e

pushd ~/.files

echo "==> Updating Homebrew packages..."
brew update
brew outdated
brew upgrade

echo "==> Updating Mac App Store apps..."
mas upgrade

echo "==> Updating asdf plugins..."
if command -v asdf >/dev/null; then
	asdf plugin update --all 2>/dev/null || true
fi

popd
